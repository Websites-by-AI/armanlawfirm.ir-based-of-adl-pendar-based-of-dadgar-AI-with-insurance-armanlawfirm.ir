# ─────────────────────────────────────────────────────────────
#  Arman Law Firm — Environment Variables Template
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  On Replit:          use Secrets panel (🔒) — NOT .env file
#  On Cloudflare Pages: Settings → Environment Variables
#  On Render.com:      Environment → Add Environment Variable
# ─────────────────────────────────────────────────────────────

# ── Required: Google Gemini AI ────────────────────────────────
# Free key at: https://ai.google.dev → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required: Supabase (Database + Auth) ─────────────────────
# Create project at: https://supabase.com
# Find in: Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── For Cloudflare Pages (Vite build-time vars) ───────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ─────────────────────────────────────────────────
NODE_ENV=development
NODE_VERSION=20
PORT=3001

# ── If using separate backend (Render.com) ────────────────────
# VITE_API_URL=https://armanlawfirm-api.onrender.com
